# ============================================================
# TEMPLATE — copy to secret.yaml, fill in real values,
# then apply with: kubectl apply -f k8s/secret.yaml
#
# secret.yaml is gitignored. Never commit it.
# ============================================================
#
# All values must be base64-encoded:
#   echo -n "your-value" | base64
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: telegram-sorter-secrets
  namespace: telegram-sorter
type: Opaque
data:
  # echo -n "34729368" | base64
  TELEGRAM_API_ID: BASE64_ENCODED_API_ID

  # echo -n "b60588852ec27dbdffbacb2132d25a3b" | base64
  TELEGRAM_API_HASH: BASE64_ENCODED_API_HASH

  # echo -n "8793143062:AAE1YTX..." | base64
  TELEGRAM_BOT_TOKEN: BASE64_ENCODED_BOT_TOKEN

  # Generated by: python scripts/setup_session.py
  TELEGRAM_SESSION_STRING: BASE64_ENCODED_SESSION_STRING

  # echo -n "sk-proj-..." | base64
  OPENAI_API_KEY: BASE64_ENCODED_OPENAI_KEY

